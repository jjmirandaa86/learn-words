MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# Optional: change this if your table has another name.
MYSQL_WORDS_TABLE=

# Optional: default number of words to load.
MYSQL_WORDS_LIMIT=50

# Optional: Merriam-Webster pronunciation audio lookup.
MERRIAM_WEBSTER_API_KEY=your_api_key
MERRIAM_WEBSTER_REFERENCE=spanish

# Optional: Unsplash images for Anki cards.
# https://unsplash.com/documentation
# https://unsplash.com/account
UNSPLASH_ACCESS_KEY=your_access_key
UNSPLASH_SECRET_KEY=your_secret_key
